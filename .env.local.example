# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Claude Haiku - daily search)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google (Gemini 3.1 Flash-Lite - translation + instructions)
GEMINI_API_KEY=your_google_ai_studio_api_key

# Admin page protection (simple password for /add route)
ADMIN_PASSWORD=choose_a_strong_password

# This secret is used by GitHub Actions to call /api/daily
CRON_SECRET=choose_a_random_secret_string
